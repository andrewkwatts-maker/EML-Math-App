#:import dp kivy.metrics.dp
#:import TreeImageView eml_math_app.widgets.svg_view.TreeImageView


<CompressScreen>:
    name: "compress"
    expr_field:           expr_in
    x_lo_field:           x_lo
    x_hi_field:           x_hi
    n_points_field:       n_pts
    precision_field:      prec
    max_complexity_field: max_c
    tree_view:            tree
    formula_label:        formula_lbl
    error_label:          error_lbl
    complexity_label:     complexity_lbl

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(8)

        MDTopAppBar:
            title: "Compress"
            left_action_items: [["arrow-left", lambda x: setattr(app.root, "current", "convert")]]
            right_action_items: [["arrow-right", lambda x: setattr(app.root, "current", "constants")]]

        MDTextField:
            id: expr_in
            hint_text: "Function in x  (sin(x)**2 + cos(x)**2)"
            mode: "rectangle"
            size_hint_y: None
            height: dp(56)

        MDGridLayout:
            cols: 5
            spacing: dp(8)
            size_hint_y: None
            height: dp(56)
            MDTextField:
                id: x_lo
                hint_text: "x_lo";  text: "0.2";  mode: "rectangle"
            MDTextField:
                id: x_hi
                hint_text: "x_hi";  text: "3.0";  mode: "rectangle"
            MDTextField:
                id: n_pts
                hint_text: "n_pts"; text: "40";   mode: "rectangle"
            MDTextField:
                id: prec
                hint_text: "ε";     text: "1e-8"; mode: "rectangle"
            MDTextField:
                id: max_c
                hint_text: "depth"; text: "8";    mode: "rectangle"

        MDRaisedButton:
            text: "Compress"
            on_release: root.run_compression()
            size_hint_x: None
            width: dp(140)

        MDLabel:
            id: formula_lbl
            text: ""
        MDLabel:
            id: error_lbl
            text: ""
            theme_text_color: "Hint"
        MDLabel:
            id: complexity_lbl
            text: ""
            theme_text_color: "Hint"

        MDLabel:
            text: root.status
            theme_text_color: "Secondary"
            size_hint_y: None
            height: dp(20)

        TreeImageView:
            id: tree
            allow_stretch: True
            keep_ratio: True
