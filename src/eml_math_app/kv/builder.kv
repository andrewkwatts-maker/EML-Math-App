#:import dp kivy.metrics.dp
#:import FormulaInput eml_math_app.widgets.formula_input.FormulaInput
#:import TreeImageView eml_math_app.widgets.svg_view.TreeImageView


<BuilderScreen>:
    name: "builder"
    formula_field: formula
    tree_view: tree

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(8)

        MDTopAppBar:
            title: "Builder"
            left_action_items: [["arrow-left", lambda x: setattr(app.root, "current", "home")]]
            right_action_items: [["arrow-right", lambda x: setattr(app.root, "current", "convert")]]

        FormulaInput:
            id: formula
            hint_text: "Expression (Python or EML form)"
            mode: "rectangle"
            size_hint_y: None
            height: dp(56)

        MDBoxLayout:
            adaptive_height: True
            spacing: dp(8)
            MDLabel:
                text: "Direction:"
                size_hint_x: None
                width: dp(80)
            MDFlatButton:
                text: "down";  on_release: root.set_direction("down")
            MDFlatButton:
                text: "up";    on_release: root.set_direction("up")
            MDFlatButton:
                text: "left";  on_release: root.set_direction("left")
            MDFlatButton:
                text: "right"; on_release: root.set_direction("right")

        MDBoxLayout:
            adaptive_height: True
            spacing: dp(8)
            MDLabel:
                text: "Edges:"
                size_hint_x: None
                width: dp(80)
            MDFlatButton:
                text: "straight"; on_release: root.set_edge_style("straight")
            MDFlatButton:
                text: "curve";    on_release: root.set_edge_style("curve")
            MDFlatButton:
                text: "spline";   on_release: root.set_edge_style("spline")

        MDLabel:
            text: root.status
            theme_text_color: "Hint"
            size_hint_y: None
            height: dp(24)

        TreeImageView:
            id: tree
            allow_stretch: True
            keep_ratio: True
