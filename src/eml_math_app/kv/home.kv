#:import dp kivy.metrics.dp


# ─── Reusable: example "chip" — clicking sets the input field ─────────────────
<ExampleChip@MDFlatButton>:
    expression: ""
    on_release: app.root.load_example(self.expression)
    size_hint_y: None
    height: dp(32)
    md_bg_color: app.theme_cls.bg_normal
    line_color: app.theme_cls.primary_color


# ─── Reusable: card surrounding a render area ─────────────────────────────────
<Card@MDBoxLayout>:
    md_bg_color: 0.11, 0.11, 0.13, 1
    radius: [dp(8),]
    padding: dp(8)


# ─── Visual styling for the CopyChip Python widget defined in
# widgets/copy_chip.py — title-as-trigger, hover shows preview tooltip.
<CopyChip>:
    size_hint_x: 1
    md_bg_color: app.theme_cls.bg_normal
    line_color: app.theme_cls.divider_color
    tooltip_text: self.preview if self.preview else "(empty)"




<HomeScreen>:
    expr_field: expr_field
    latex_preview_normal: latex_preview_normal
    latex_preview_eml: latex_preview_eml
    tree_view: tree_view

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(8)
        spacing: dp(6)

        # ─── Header strip — compact title + chip scroller in one row.
        # Saves a full row of vertical space vs the previous two-row
        # title-then-chip layout, giving the graph more breathing room.
        MDBoxLayout:
            size_hint_y: None
            height: dp(36)
            spacing: dp(8)
            MDLabel:
                text: "EML-Math"
                font_style: "Subtitle1"
                bold: True
                size_hint_x: None
                width: dp(110)
                valign: "center"
            ScrollView:
                size_hint_y: None
                height: dp(36)
                do_scroll_y: False
                MDBoxLayout:
                    id: chip_row
                    adaptive_width: True
                    spacing: dp(4)

        # ─── Input row ────────────────────────────────────────────────────
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(8)

            ExprInput:
                id: expr_field
                hint_text: "Math expression — type freely; right-click for function names"
                text: "(1/x) + (y**3)"
                mode: "rectangle"
                multiline: False

            MDRaisedButton:
                text: "Compress"
                on_release: root.compress_now()
                size_hint_x: None
                width: dp(108)

            MDFlatButton:
                text: "Clear"
                on_release: root.clear()
                size_hint_x: None
                width: dp(64)

        # ─── View pill switch ─────────────────────────────────────────────
        # Two segments — Typed expression vs Compressed search result. Both
        # the LaTeX preview and the EML graph swap together when toggled.
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(6)
            MDLabel:
                text: "View:"
                theme_text_color: "Hint"
                size_hint_x: None
                width: dp(46)
            MDFlatButton:
                text: "Typed"
                size_hint_x: None
                width: dp(96)
                md_bg_color: app.theme_cls.primary_color if not root.show_compressed else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_compressed(False)
            MDFlatButton:
                text: "Compressed"
                size_hint_x: None
                width: dp(140)
                md_bg_color: app.theme_cls.primary_color if root.show_compressed else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_compressed(True)
            Widget:

        # ─── Side-by-side LaTeX previews ──────────────────────────────────
        # Left  — normal-math LaTeX (mul/div/pow patterns recognised).
        # Right — literal EML primitive LaTeX (verbose exp/ln/eml chain).
        # Pill switch (Typed / Compressed) swaps both panes together.
        MDBoxLayout:
            size_hint_y: None
            height: dp(110)
            spacing: dp(8)

            Card:
                orientation: "vertical"
                size_hint_x: 1
                MDLabel:
                    text: "Normal math"
                    font_style: "Caption"
                    theme_text_color: "Hint"
                    size_hint_y: None
                    height: dp(16)
                LatexPreview:
                    id: latex_preview_normal
                    allow_stretch: True
                    keep_ratio: True

            Card:
                orientation: "vertical"
                size_hint_x: 1
                MDLabel:
                    text: "EML primitive"
                    font_style: "Caption"
                    theme_text_color: "Hint"
                    size_hint_y: None
                    height: dp(16)
                LatexPreview:
                    id: latex_preview_eml
                    allow_stretch: True
                    keep_ratio: True

        # ─── Status + hover hint ──────────────────────────────────────────
        MDLabel:
            text: root.status
            theme_text_color: "Hint"
            size_hint_y: None
            height: dp(20)
            shorten: True
            shorten_from: "right"


        # ─── Direction switcher + label toggle ────────────────────────────
        # Material-icon buttons render reliably with the bundled font;
        # Unicode arrows often miss in PyInstaller'd builds. The "labels"
        # toggle hides every node label (hover still works) — useful when
        # you just want to read the tree shape.
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(2)
            MDLabel:
                text: "Direction:"
                theme_text_color: "Hint"
                size_hint_x: None
                width: dp(82)
            MDIconButton:
                icon: "arrow-down"
                theme_icon_color: "Custom"
                icon_color: app.theme_cls.primary_color if root.tree_direction == "down" else (0.7, 0.7, 0.75, 1)
                on_release: root.set_direction("down")
            MDIconButton:
                icon: "arrow-up"
                theme_icon_color: "Custom"
                icon_color: app.theme_cls.primary_color if root.tree_direction == "up" else (0.7, 0.7, 0.75, 1)
                on_release: root.set_direction("up")
            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: app.theme_cls.primary_color if root.tree_direction == "left" else (0.7, 0.7, 0.75, 1)
                on_release: root.set_direction("left")
            MDIconButton:
                icon: "arrow-right"
                theme_icon_color: "Custom"
                icon_color: app.theme_cls.primary_color if root.tree_direction == "right" else (0.7, 0.7, 0.75, 1)
                on_release: root.set_direction("right")
            Widget:
                size_hint_x: None
                width: dp(16)
            MDLabel:
                text: "Labels:"
                theme_text_color: "Hint"
                size_hint_x: None
                width: dp(60)
            MDIconButton:
                icon: "eye" if root.show_labels else "eye-off"
                theme_icon_color: "Custom"
                icon_color: app.theme_cls.primary_color if root.show_labels else (0.7, 0.7, 0.75, 1)
                on_release: root.toggle_labels()
            Widget:

        # ─── Tree render ──────────────────────────────────────────────────
        Card:
            size_hint_y: 1
            TreeImageView:
                id: tree_view
                allow_stretch: True
                keep_ratio: True

        # ─── Output strip ─────────────────────────────────────────────────
        # Four compact "click-to-copy" buttons. The button's text is just
        # the format name (EML / LaTeX / Python / JSON); clicking copies
        # the rendered string for that format to the clipboard, and an
        # MDTooltip on long-press shows a preview so the user knows what
        # they're about to copy.
        MDBoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)
            CopyChip:
                text: "Copy EML"
                preview: root.copy_eml
                on_release: root.copy_text(root.copy_eml, "EML")
            CopyChip:
                text: "Copy LaTeX"
                preview: root.copy_latex
                on_release: root.copy_text(root.copy_latex, "LaTeX")
            CopyChip:
                text: "Copy Python"
                preview: root.copy_python
                on_release: root.copy_text(root.copy_python, "Python")
            CopyChip:
                text: "Copy JSON"
                preview: root.copy_json
                on_release: root.copy_text(root.copy_json, "JSON")
