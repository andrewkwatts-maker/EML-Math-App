#:import dp kivy.metrics.dp


# ─── Reusable: example "chip" — clicking sets the input field ─────────────────
<ExampleChip@MDFlatButton>:
    expression: ""
    on_release: app.root.load_example(self.expression)
    size_hint_y: None
    height: dp(32)
    md_bg_color: app.theme_cls.bg_normal
    line_color: app.theme_cls.primary_color


# ─── Reusable: card surrounding a render area ─────────────────────────────────
<Card@MDBoxLayout>:
    md_bg_color: 0.11, 0.11, 0.13, 1
    radius: [dp(8),]
    padding: dp(8)




<HomeScreen>:
    expr_field: expr_field
    latex_preview_normal: latex_preview_normal
    latex_preview_eml: latex_preview_eml
    tree_view: tree_view
    eml_field: eml_field
    latex_field: latex_field
    python_field: python_field
    json_field: json_field

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(14)
        spacing: dp(10)

        # ─── Title strip ─────────────────────────────────────────────────
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(12)
            MDLabel:
                text: "EML-Math"
                font_style: "H5"
                bold: True
                size_hint_x: None
                width: dp(150)
            MDLabel:
                text: "type / paste any expression  ·  rendered live  ·  hover the tree"
                theme_text_color: "Hint"

        # ─── Example chips — populated at runtime from
        # services.famous.all_famous() (every named equation in eml-math). ─
        ScrollView:
            size_hint_y: None
            height: dp(40)
            do_scroll_y: False
            MDBoxLayout:
                id: chip_row
                adaptive_width: True
                spacing: dp(6)

        # ─── Input row ────────────────────────────────────────────────────
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(8)

            ExprInput:
                id: expr_field
                hint_text: "Math expression — type freely; right-click for function names"
                text: "(1/x) + (y**3)"
                mode: "rectangle"
                multiline: False

            MDRaisedButton:
                text: "Compress"
                on_release: root.compress_now()
                size_hint_x: None
                width: dp(108)

            MDFlatButton:
                text: "Clear"
                on_release: root.clear()
                size_hint_x: None
                width: dp(64)

        # ─── View pill switch ─────────────────────────────────────────────
        # Two segments — Typed expression vs Compressed search result. Both
        # the LaTeX preview and the EML graph swap together when toggled.
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(6)
            MDLabel:
                text: "View:"
                theme_text_color: "Hint"
                size_hint_x: None
                width: dp(46)
            MDFlatButton:
                text: "Typed"
                size_hint_x: None
                width: dp(96)
                md_bg_color: app.theme_cls.primary_color if not root.show_compressed else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_compressed(False)
            MDFlatButton:
                text: "Compressed"
                size_hint_x: None
                width: dp(140)
                md_bg_color: app.theme_cls.primary_color if root.show_compressed else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_compressed(True)
            Widget:

        # ─── Side-by-side LaTeX previews ──────────────────────────────────
        # Left  — normal-math LaTeX (mul/div/pow patterns recognised).
        # Right — literal EML primitive LaTeX (verbose exp/ln/eml chain).
        # Pill switch (Typed / Compressed) swaps both panes together.
        MDBoxLayout:
            size_hint_y: None
            height: dp(110)
            spacing: dp(8)

            Card:
                orientation: "vertical"
                size_hint_x: 1
                MDLabel:
                    text: "Normal math"
                    font_style: "Caption"
                    theme_text_color: "Hint"
                    size_hint_y: None
                    height: dp(16)
                LatexPreview:
                    id: latex_preview_normal
                    allow_stretch: True
                    keep_ratio: True

            Card:
                orientation: "vertical"
                size_hint_x: 1
                MDLabel:
                    text: "EML primitive"
                    font_style: "Caption"
                    theme_text_color: "Hint"
                    size_hint_y: None
                    height: dp(16)
                LatexPreview:
                    id: latex_preview_eml
                    allow_stretch: True
                    keep_ratio: True

        # ─── Status + hover hint ──────────────────────────────────────────
        MDLabel:
            text: root.status
            theme_text_color: "Hint"
            size_hint_y: None
            height: dp(20)
            shorten: True
            shorten_from: "right"

        MDLabel:
            text: root.hover_info
            theme_text_color: "Secondary"
            size_hint_y: None
            height: dp(18)
            shorten: True
            shorten_from: "right"

        # ─── Direction switcher ───────────────────────────────────────────
        # Four arrow buttons. The active direction is highlighted with the
        # primary palette; clicking another flips the graph and re-renders.
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(4)
            MDLabel:
                text: "Direction:"
                theme_text_color: "Hint"
                size_hint_x: None
                width: dp(82)
            MDFlatButton:
                text: "↓"
                size_hint_x: None
                width: dp(48)
                md_bg_color: app.theme_cls.primary_color if root.tree_direction == "down" else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_direction("down")
            MDFlatButton:
                text: "↑"
                size_hint_x: None
                width: dp(48)
                md_bg_color: app.theme_cls.primary_color if root.tree_direction == "up" else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_direction("up")
            MDFlatButton:
                text: "←"
                size_hint_x: None
                width: dp(48)
                md_bg_color: app.theme_cls.primary_color if root.tree_direction == "left" else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_direction("left")
            MDFlatButton:
                text: "→"
                size_hint_x: None
                width: dp(48)
                md_bg_color: app.theme_cls.primary_color if root.tree_direction == "right" else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_direction("right")
            Widget:

        # ─── Tree render ──────────────────────────────────────────────────
        Card:
            size_hint_y: 1
            TreeImageView:
                id: tree_view
                allow_stretch: True
                keep_ratio: True

        # ─── Output strip ─────────────────────────────────────────────────
        # Four fixed-height columns. Each holds a header (label + Copy
        # button) and a ScrollView whose visible height never changes; the
        # inner Label grows with content and scrolls inside the card. This
        # is what stops the JSON dump from bleeding up into the tree area.
        MDGridLayout:
            cols: 4
            spacing: dp(6)
            size_hint_y: None
            height: dp(140)

            # ── EML column ────────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "EML"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(eml_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: eml_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)

            # ── LaTeX column ──────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "LaTeX"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(latex_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: latex_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)

            # ── Python column ─────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "Python"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(python_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: python_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)

            # ── JSON column ───────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "JSON"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(json_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: json_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)
