#:import dp kivy.metrics.dp


# ─── Reusable: small flat key on the calculator pad ───────────────────────────
<KeyButton@MDFlatButton>:
    frag: ""
    on_release: app.root.insert(self.frag) if self.frag else None
    size_hint: 1, None
    height: dp(38)
    md_bg_color: app.theme_cls.bg_normal
    line_color: app.theme_cls.divider_color


# ─── Reusable: example "chip" — clicking sets the input field ─────────────────
<ExampleChip@MDFlatButton>:
    expression: ""
    on_release: app.root.load_example(self.expression)
    size_hint_y: None
    height: dp(32)
    md_bg_color: app.theme_cls.bg_normal
    line_color: app.theme_cls.primary_color


# ─── Reusable: card surrounding a render area ─────────────────────────────────
<Card@MDBoxLayout>:
    md_bg_color: 0.11, 0.11, 0.13, 1
    radius: [dp(8),]
    padding: dp(8)




<HomeScreen>:
    expr_field: expr_field
    latex_preview: latex_preview
    tree_view: tree_view
    eml_field: eml_field
    latex_field: latex_field
    python_field: python_field
    json_field: json_field

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(14)
        spacing: dp(10)

        # ─── Title strip ─────────────────────────────────────────────────
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(12)
            MDLabel:
                text: "EML-Math"
                font_style: "H5"
                bold: True
                size_hint_x: None
                width: dp(150)
            MDLabel:
                text: "type / paste any expression  ·  rendered live  ·  hover the tree"
                theme_text_color: "Hint"

        # ─── Example chips — populated at runtime from
        # services.famous.all_famous() (every named equation in eml-math). ─
        ScrollView:
            size_hint_y: None
            height: dp(40)
            do_scroll_y: False
            MDBoxLayout:
                id: chip_row
                adaptive_width: True
                spacing: dp(6)

        # ─── Input row ────────────────────────────────────────────────────
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(8)

            MDTextField:
                id: expr_field
                hint_text: "Math expression — type freely; use the pad for function names"
                text: "(1/x) + (y**3)"
                mode: "rectangle"
                multiline: False

            MDRaisedButton:
                text: "Compress"
                on_release: root.compress_now()
                size_hint_x: None
                width: dp(108)

            MDFlatButton:
                text: "Clear"
                on_release: root.clear()
                size_hint_x: None
                width: dp(64)

        # ─── View pill switch ─────────────────────────────────────────────
        # Two segments — Typed expression vs Compressed search result. Both
        # the LaTeX preview and the EML graph swap together when toggled.
        MDBoxLayout:
            adaptive_height: True
            spacing: dp(6)
            MDLabel:
                text: "View:"
                theme_text_color: "Hint"
                size_hint_x: None
                width: dp(46)
            MDFlatButton:
                text: "Typed"
                size_hint_x: None
                width: dp(96)
                md_bg_color: app.theme_cls.primary_color if not root.show_compressed else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_compressed(False)
            MDFlatButton:
                text: "Compressed"
                size_hint_x: None
                width: dp(140)
                md_bg_color: app.theme_cls.primary_color if root.show_compressed else app.theme_cls.bg_normal
                line_color: app.theme_cls.primary_color
                on_release: root.set_compressed(True)
            Widget:

        # ─── LaTeX preview ────────────────────────────────────────────────
        Card:
            size_hint_y: None
            height: dp(96)
            LatexPreview:
                id: latex_preview
                allow_stretch: True
                keep_ratio: True

        # ─── Calculator pad: function names only ──────────────────────────
        MDGridLayout:
            cols: 6
            spacing: dp(4)
            adaptive_height: True

            KeyButton:
                text: "sin"
                frag: "sin("
            KeyButton:
                text: "cos"
                frag: "cos("
            KeyButton:
                text: "tan"
                frag: "tan("
            KeyButton:
                text: "ln"
                frag: "log("
            KeyButton:
                text: "log₁₀"
                frag: "log10("
            KeyButton:
                text: "exp"
                frag: "exp("

            KeyButton:
                text: "√"
                frag: "sqrt("
            KeyButton:
                text: "abs"
                frag: "abs("
            KeyButton:
                text: "π"
                frag: "pi"
            KeyButton:
                text: "e"
                frag: "e"
            KeyButton:
                text: "^"
                frag: "**"
            KeyButton:
                text: "⌫"
                on_release: root.backspace()
                frag: ""

        # ─── Status + hover hint ──────────────────────────────────────────
        MDLabel:
            text: root.status
            theme_text_color: "Hint"
            size_hint_y: None
            height: dp(20)
            shorten: True
            shorten_from: "right"

        MDLabel:
            text: root.hover_info
            theme_text_color: "Secondary"
            size_hint_y: None
            height: dp(18)
            shorten: True
            shorten_from: "right"

        # ─── Tree render ──────────────────────────────────────────────────
        Card:
            size_hint_y: 1
            TreeImageView:
                id: tree_view
                allow_stretch: True
                keep_ratio: True

        # ─── Output strip ─────────────────────────────────────────────────
        # Four fixed-height columns. Each holds a header (label + Copy
        # button) and a ScrollView whose visible height never changes; the
        # inner Label grows with content and scrolls inside the card. This
        # is what stops the JSON dump from bleeding up into the tree area.
        MDGridLayout:
            cols: 4
            spacing: dp(6)
            size_hint_y: None
            height: dp(140)

            # ── EML column ────────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "EML"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(eml_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: eml_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)

            # ── LaTeX column ──────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "LaTeX"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(latex_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: latex_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)

            # ── Python column ─────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "Python"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(python_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: python_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)

            # ── JSON column ───────────────────────────────────────────────
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(2)
                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "JSON"
                        font_style: "Caption"
                        size_hint_x: 1
                    MDFlatButton:
                        text: "Copy"
                        size_hint_x: None
                        width: dp(60)
                        on_release: root.copy_field(json_field)
                MDBoxLayout:
                    md_bg_color: 0.08, 0.08, 0.10, 1
                    radius: [dp(6),]
                    padding: dp(2)
                    size_hint_y: None
                    height: dp(108)
                    ScrollView:
                        do_scroll_x: False
                        bar_width: dp(4)
                        Label:
                            id: json_field
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            color: 0.92, 0.92, 0.94, 1
                            font_size: dp(12)
                            halign: "left"
                            valign: "top"
                            padding: dp(6), dp(4)
