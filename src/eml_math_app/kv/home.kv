#:import dp kivy.metrics.dp


<HomeScreen>:
    name: "home"
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(12)

        MDLabel:
            text: f"EML-Math-App  [v{root.version}]"
            font_style: "H4"
            halign: "left"
            size_hint_y: None
            height: dp(56)

        MDLabel:
            text: f"Backed by eml-math {root.eml_version}"
            theme_text_color: "Hint"
            size_hint_y: None
            height: dp(28)

        MDLabel:
            text: "Visual explorer for the EML Sheffer operator. Build expressions, render the binary tree, browse 136 named constants, run the compress / decompress pipeline, export to SVG / PNG / PDF / MathJax."
            theme_text_color: "Secondary"
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None

        MDGridLayout:
            cols: 2
            spacing: dp(12)
            adaptive_height: True

            MDRaisedButton:
                text: "Builder"
                on_release: app.root.current = "builder"
                size_hint_x: 1
            MDRaisedButton:
                text: "Convert"
                on_release: app.root.current = "convert"
                size_hint_x: 1
            MDRaisedButton:
                text: "Compress"
                on_release: app.root.current = "compress"
                size_hint_x: 1
            MDRaisedButton:
                text: "Constants"
                on_release: app.root.current = "constants"
                size_hint_x: 1
            MDRaisedButton:
                text: "Export"
                on_release: app.root.current = "export"
                size_hint_x: 1
            MDFlatButton:
                text: "About"
                on_release: app.root.current = "about"
                size_hint_x: 1

        Widget:
