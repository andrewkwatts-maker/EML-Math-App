#:import dp kivy.metrics.dp


<ExportScreen>:
    name: "export"
    expr_field:    expr_in
    out_dir_field: out_dir

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(8)

        MDTopAppBar:
            title: "Export"
            left_action_items: [["arrow-left", lambda x: setattr(app.root, "current", "constants")]]
            right_action_items: [["arrow-right", lambda x: setattr(app.root, "current", "about")]]

        MDTextField:
            id: expr_in
            hint_text: "Expression"
            mode: "rectangle"
            size_hint_y: None
            height: dp(56)

        MDTextField:
            id: out_dir
            hint_text: "Output directory (defaults to cwd)"
            mode: "rectangle"
            size_hint_y: None
            height: dp(56)

        MDGridLayout:
            cols: 4
            spacing: dp(8)
            adaptive_height: True
            MDRaisedButton:
                text: "SVG";  on_release: root.export("svg")
            MDRaisedButton:
                text: "HTML"; on_release: root.export("html")
            MDRaisedButton:
                text: "PNG";  on_release: root.export("png")
            MDRaisedButton:
                text: "PDF";  on_release: root.export("pdf")

        MDLabel:
            text: root.status
            theme_text_color: "Secondary"

        Widget:
