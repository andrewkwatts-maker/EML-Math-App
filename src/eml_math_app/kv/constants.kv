#:import dp kivy.metrics.dp


<ConstantsScreen>:
    name: "constants"
    list_widget:  list_box
    detail_label: detail
    search_field: search

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(8)

        MDTopAppBar:
            title: "Constants"
            left_action_items: [["arrow-left", lambda x: setattr(app.root, "current", "compress")]]
            right_action_items: [["arrow-right", lambda x: setattr(app.root, "current", "export")]]

        MDTextField:
            id: search
            hint_text: "Filter (pi, sqrt, phi, …)"
            mode: "rectangle"
            on_text: root.filter_changed(self.text)
            size_hint_y: None
            height: dp(48)

        MDBoxLayout:
            orientation: "horizontal"
            spacing: dp(12)

            ScrollView:
                size_hint_x: 0.4
                MDList:
                    id: list_box

            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: 0.6
                padding: dp(8)
                MDLabel:
                    id: detail
                    text: root.detail_text
                    text_size: self.width, None
                    valign: "top"
                    size_hint_y: None
                    height: self.texture_size[1]
